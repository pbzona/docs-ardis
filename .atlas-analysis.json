  "keyFeatures": [
    "Create PostgreSQL, MySQL, and Redis containers with a single command",
    "Interactive menus with vim keybindings or fully non-interactive with flags",
    "Automatic TTL-based container cleanup (default 2 hours, configurable)",
    "Encrypted credential storage using AES-256-GCM",
    "Auto-generated connection strings in environment variable format",
    "Named and custom volume management with automatic creation",
    "Additional database user management",
    "Automatic port conflict resolution",
    "One-command credential rotation"
  ],
  "publicApiSurface": [
    "mkdb start [--db] [--name] [--version] [--port] [--volume] [--ttl] [--repeat] [--no-auth]",
    "mkdb list / mkdb ls [--type] [--status]",
    "mkdb stop [--name]",
    "mkdb restart [--name]",
    "mkdb info [--name]",
    "mkdb remove / mkdb rm [--name]",
    "mkdb creds get [--name]",
    "mkdb creds copy [--name]",
    "mkdb creds rotate [--name]",
    "mkdb user create [--name]",
    "mkdb user delete [--name]",
    "mkdb extend [--name] [--hours]",
    "mkdb test / mkdb ping [--name]",
    "mkdb config",
    "mkdb cleanup",
    "mkdb version"
  ]
}
